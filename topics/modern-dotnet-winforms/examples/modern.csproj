<!-- A modern SDK-style WinForms project file (.NET 7). -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net7.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>

    <!-- Modern defaults worth enabling -->
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>

    <!-- High-DPI + app identity -->
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <ApplicationIcon>app.ico</ApplicationIcon>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <!-- NuGet packages, the modern way -->
  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="7.0.*" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="7.0.*" />
  </ItemGroup>

</Project>
