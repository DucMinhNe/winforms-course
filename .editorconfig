root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.cs]
indent_size = 4
# Favour modern C#: file-scoped namespaces, var where the type is obvious.
csharp_style_namespace_declarations = file_scoped:suggestion

[*.{md,yml,yaml,json,csproj,xml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
